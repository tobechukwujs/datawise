# Set to true to skip Claude API calls and return hardcoded charts (useful for UI dev)
USE_MOCK_AI=false

# Primary connection (via PgBouncer pooler)
DATABASE_URL="postgresql://user:password@db.supabase.co:6543/postgres?pgbouncer=true"
# Direct connection (used by Prisma Migrate)
DIRECT_URL="postgresql://user:password@db.supabase.co:5432/postgres"

ANTHROPIC_API_KEY="your-api-key"

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="generate-a-random-secret"
NEXTAUTH_URL="http://localhost:3000"

GITHUB_CLIENT_ID="your-github-oauth-id"
GITHUB_CLIENT_SECRET="your-github-oauth-secret"

GOOGLE_CLIENT_ID="your-google-oauth-id"
GOOGLE_CLIENT_SECRET="your-google-oauth-secret"

# Vercel Blob — add via Vercel dashboard: Storage → Create → Blob
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."
